# =============================================================================
# Trident — CI smoke-test environment
# =============================================================================
# Used exclusively by the e2e GitHub Actions job.
# These values are intentionally weak/predictable — they exist only to wire
# the Docker Compose stack together inside an ephemeral CI runner.
#
# DO NOT use any of these values in staging or production.
# =============================================================================

# -----------------------------------------------------------------------------
# Shared — Postgres credentials (matches the postgres service in docker-compose)
# -----------------------------------------------------------------------------
POSTGRES_USER=trident
POSTGRES_PASSWORD=ci-password
POSTGRES_DB=trident

# -----------------------------------------------------------------------------
# Service connection strings
# Services connect directly to postgres:5432 in CI (PgBouncer is disabled).
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://trident:ci-password@postgres:5432/trident
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# Rust gRPC API
# -----------------------------------------------------------------------------
GRPC_ADDR=0.0.0.0:50051
GRPC_API_DB_POOL_SIZE=5

# -----------------------------------------------------------------------------
# Rust indexer
# STELLAR_RPC_URL points at the public testnet RPC. The indexer will start
# polling but the smoke test does not assert on event data — only on 200 OK
# from /v1/events. A slow or unreachable RPC will not block the health check.
# -----------------------------------------------------------------------------
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NETWORK=testnet
POLL_INTERVAL_MS=5000
INDEX_DIAGNOSTIC=false
METRICS_PORT=9090
INDEXER_DB_POOL_SIZE=3

# -----------------------------------------------------------------------------
# Go REST API
# GRPC_ADDR is read by main.go to connect to the gRPC service.
# API_KEY_SALT + API_KEY_HASHES together authenticate the CI test key.
#
# Raw test key : ci-test-api-key-do-not-use-in-production
# Salt         : ci-test-salt
# Hash         : echo -n "ci-test-api-key-do-not-use-in-production" \
#                  | openssl dgst -sha256 -hmac "ci-test-salt" \
#                  | awk '{print $2}'
#
# DO NOT use this salt or key outside CI.
# -----------------------------------------------------------------------------
PORT=3000
API_KEY_SALT=ci-test-salt
API_KEY_HASHES=02f464c47994f7237aa6a9fc7c1dfa0b4b6d7b2f407fd3bd08e131670cac43cf
ADMIN_API_KEY=ci-admin-key-do-not-use-in-production

# -----------------------------------------------------------------------------
# Pool sizing
# -----------------------------------------------------------------------------
GO_API_DB_POOL_SIZE=5

# -----------------------------------------------------------------------------
# Logging — info level is enough to diagnose failures; trace is too noisy
# -----------------------------------------------------------------------------
LOG_LEVEL=info
RUST_LOG=info
