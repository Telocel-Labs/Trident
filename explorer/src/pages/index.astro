---
import Base from '../layouts/Base.astro';
import { listEvents } from '../lib/api';
import { truncate, relativeTime } from '../lib/format';
import type { Network } from '../lib/types';

const rawNetwork = Astro.url.searchParams.get('network');
const network: Network = rawNetwork === 'mainnet' ? 'mainnet' : 'testnet';

// No-JS search redirect: ?q=C...
const searchQuery = Astro.url.searchParams.get('q')?.trim();
if (searchQuery) {
  return Astro.redirect(`/contract/${encodeURIComponent(searchQuery)}?network=${network}`);
}

let recentEvents: Awaited<ReturnType<typeof listEvents>>['events'] = [];
try {
  const result = await listEvents({ limit: 10, network });
  recentEvents = result.events;
} catch {
  // non-critical — ticker is empty on API failure
}
---

<Base
  title="Soroban Event Explorer"
  description="Browse Soroban smart contract events on Stellar. No API key required."
>
  <!-- Hero -->
  <section class="text-center py-14">
    <h1 class="text-4xl font-bold mb-3 text-white">Soroban Event Explorer</h1>
    <p class="text-gray-400 mb-8 text-lg">
      Browse contract events on the Stellar network — no API key required.
    </p>

    <!-- Search form (works without JS via ?q= redirect) -->
    <form method="get" class="flex gap-2 max-w-2xl mx-auto" id="search-form">
      <input
        type="text"
        name="q"
        id="contract-input"
        placeholder="Soroban contract address (C...)"
        class="flex-1 px-4 py-2.5 rounded-lg bg-gray-800 border border-gray-700 text-white placeholder-gray-500 focus:outline-none focus:border-indigo-500 font-mono text-sm"
        autocomplete="off"
        spellcheck="false"
      />
      <input type="hidden" name="network" value={network} />
      <button
        type="submit"
        class="px-6 py-2.5 bg-indigo-600 hover:bg-indigo-500 active:bg-indigo-700 rounded-lg text-white font-semibold text-sm transition-colors"
      >
        Explore
      </button>
    </form>

    <!-- Network toggle -->
    <div class="mt-4 flex justify-center gap-2 text-sm" role="group" aria-label="Network selector">
      <a
        href="?network=testnet"
        class={`px-4 py-1.5 rounded-full font-medium transition-colors ${
          network === 'testnet'
            ? 'bg-indigo-600 text-white'
            : 'text-gray-400 hover:text-white hover:bg-gray-800'
        }`}
        aria-current={network === 'testnet' ? 'true' : undefined}
      >
        Testnet
      </a>
      <a
        href="?network=mainnet"
        class={`px-4 py-1.5 rounded-full font-medium transition-colors ${
          network === 'mainnet'
            ? 'bg-indigo-600 text-white'
            : 'text-gray-400 hover:text-white hover:bg-gray-800'
        }`}
        aria-current={network === 'mainnet' ? 'true' : undefined}
      >
        Mainnet
      </a>
    </div>
  </section>

  <!-- Live ticker -->
  <section class="mt-4">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest">
        Recent Events
        <span
          id="ticker-dot"
          class="inline-block w-1.5 h-1.5 rounded-full bg-green-500 ml-2 align-middle"
          title="Live"
        ></span>
      </h2>
      <span class="text-xs text-gray-600">Updates every 5s</span>
    </div>

    <ul id="event-ticker" class="space-y-1.5" aria-live="polite" aria-label="Recent events">
      {
        recentEvents.length === 0 ? (
          <li class="text-gray-500 text-sm py-4 text-center">No recent events.</li>
        ) : (
          recentEvents.map((e) => (
            <li class="flex items-center gap-4 bg-gray-900 rounded-lg px-4 py-2.5 text-sm hover:bg-gray-800 transition-colors">
              <a
                href={`/contract/${e.contract_id}?network=${network}`}
                class="font-mono text-indigo-400 hover:text-indigo-300 truncate shrink-0 w-36"
                title={e.contract_id}
              >
                {truncate(e.contract_id)}
              </a>
              <span class="text-gray-300 truncate flex-1">
                {e.topics[0] ?? e.event_type}
              </span>
              <span class="text-gray-500 text-xs shrink-0 hidden sm:block" title={e.ledger_timestamp}>
                {relativeTime(e.ledger_timestamp)}
              </span>
              <a
                href={`/contract/${e.contract_id}/event/${e.id}?network=${network}`}
                class="text-xs text-gray-500 hover:text-white shrink-0"
                aria-label={`View event ${e.id}`}
              >
                #{e.ledger_sequence}
              </a>
            </li>
          ))
        )
      }
    </ul>
  </section>

  <!-- CTA -->
  <section class="mt-16 text-center text-sm text-gray-400">
    Need programmatic access?
    <a
      href="https://app.trident.dev/signup"
      class="text-indigo-400 hover:text-indigo-300 hover:underline"
      target="_blank"
      rel="noopener noreferrer">Get an API key</a
    > for higher rate limits and real-time subscriptions.
  </section>
</Base>

<script>
  // Enhance search form: navigate to path-based URL
  const form = document.getElementById('search-form') as HTMLFormElement | null;
  const input = document.getElementById('contract-input') as HTMLInputElement | null;
  if (form && input) {
    form.addEventListener('submit', (e) => {
      const val = input.value.trim();
      if (!val) return;
      e.preventDefault();
      const network =
        (form.querySelector('input[name="network"]') as HTMLInputElement | null)?.value ??
        'testnet';
      window.location.href = `/contract/${encodeURIComponent(val)}?network=${network}`;
    });
  }

  // Live ticker polling
  const network =
    new URLSearchParams(window.location.search).get('network') ?? 'testnet';

  function renderEvent(e: {
    contract_id: string;
    topics: string[];
    event_type: string;
    ledger_sequence: number;
    ledger_timestamp: string;
    id: string;
  }): string {
    const trunc = (s: string) =>
      s.length > 18 ? `${s.slice(0, 8)}...${s.slice(-6)}` : s;
    return `
      <li class="flex items-center gap-4 bg-gray-900 rounded-lg px-4 py-2.5 text-sm hover:bg-gray-800 transition-colors">
        <a href="/contract/${e.contract_id}?network=${network}"
           class="font-mono text-indigo-400 hover:text-indigo-300 truncate shrink-0 w-36"
           title="${e.contract_id}">${trunc(e.contract_id)}</a>
        <span class="text-gray-300 truncate flex-1">${e.topics[0] ?? e.event_type}</span>
        <span class="text-gray-500 text-xs shrink-0 hidden sm:block">&nbsp;</span>
        <a href="/contract/${e.contract_id}/event/${e.id}?network=${network}"
           class="text-xs text-gray-500 hover:text-white shrink-0">#${e.ledger_sequence}</a>
      </li>`;
  }

  async function pollTicker() {
    try {
      const res = await fetch(`/api/recent-events.json?network=${network}`);
      if (!res.ok) return;
      const events: Parameters<typeof renderEvent>[0][] = await res.json();
      const ul = document.getElementById('event-ticker');
      if (ul && events.length) {
        ul.innerHTML = events.map(renderEvent).join('');
      }
    } catch {
      // silent
    }
  }

  const id = setInterval(pollTicker, 5000);
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) clearInterval(id);
  });
</script>
