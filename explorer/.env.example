# Base URLs for the Trident REST API (no trailing slash)
TRIDENT_TESTNET_API_URL=https://api.testnet.trident.dev
TRIDENT_MAINNET_API_URL=https://api.mainnet.trident.dev

# Internal API key for the explorer (free tier — created at deploy time, never exposed to clients)
EXPLORER_API_KEY=your_internal_explorer_api_key
